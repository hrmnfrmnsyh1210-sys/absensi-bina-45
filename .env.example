# ===== Akun Admin =====
# Kredensial login admin. GANTI password untuk penggunaan nyata.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Kunci untuk menandatangani token login (stateless). Isi string acak panjang,
# mis. hasil: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=""

# ===== Penyimpanan Google Sheets (via Apps Script) =====
# Kosongkan bagian ini untuk menjalankan app dalam mode in-memory
# (data contoh, hilang saat restart) — berguna untuk mencoba lebih dulu.
#
# Cara mengisi (langkah lengkap ada di README.md dan apps-script/Code.gs):
# 1. Buka Google Spreadsheet > Extensions > Apps Script.
# 2. Tempel isi file apps-script/Code.gs, set SECRET, lalu Deploy > Web app
#    (Execute as: Me, Who has access: Anyone).
# 3. Salin URL "/exec" ke APPS_SCRIPT_URL, dan SECRET ke APPS_SCRIPT_SECRET.

# URL Web App Apps Script (berakhiran /exec).
APPS_SCRIPT_URL=""

# Harus SAMA dengan SECRET di dalam Code.gs.
APPS_SCRIPT_SECRET="ganti-dengan-rahasia-acak"

# ===== Lama (opsional, tidak dipakai fitur absensi) =====
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
# APP_URL="MY_APP_URL"
